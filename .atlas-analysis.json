  "keyFeatures": [
    "Generates API client libraries (SDKs) in 50+ languages and frameworks from an OpenAPI Specification",
    "Generates server stubs for many popular frameworks (Spring, FastAPI, Go, Node.js, etc.)",
    "Generates API documentation in HTML, Markdown, AsciiDoc, and more",
    "Supports OpenAPI Specification v2 (Swagger) and v3",
    "Highly customizable via Mustache templates and custom generators",
    "Available via CLI (npm, Homebrew, pip, Docker, JAR), Maven plugin, Gradle plugin, and online API",
    "Supports batch generation and CI/CD workflow integration",
    "Extensible plugin system for custom template engines and generators"
  ],
  "publicApiSurface": [
    "openapi-generator-cli generate -i <spec> -g <generator> -o <output>",
    "openapi-generator-cli list",
    "openapi-generator-cli validate -i <spec>",
    "openapi-generator-cli config-help -g <generator>",
    "openapi-generator-cli batch <config-file>",
    "openapi-generator-cli meta",
    "openapi-generator-cli author",
    "openapi-generator-cli version",
    "Maven Plugin: openapi-generator-maven-plugin (goal: generate)",
    "Gradle Plugin: openApiGenerate task",
    "Online REST API: POST /api/gen/clients/{language}, POST /api/gen/servers/{framework}"
  ]
